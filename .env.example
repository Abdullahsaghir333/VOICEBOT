# Copy to .env — Install deps: setup.bat (uses .\venv)
# Public HTTPS URL (ngrok / production) — Twilio must reach this for webhooks & media stream
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=voicebot

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15551234567
# Ring time before no-answer (seconds, 5–600; default 60)
TWILIO_CALL_TIMEOUT=60

# Deepgram (STT) — DEEPGRAM_API_KEY or legacy STT alias
DEEPGRAM_API_KEY=your_deepgram_api_key

# Groq (LLM)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# STT — telephony model + turn timing (custom media stream)
DEEPGRAM_MODEL=nova-2-phonecall
STT_TURN_DEBOUNCE_MS=1100
STT_ENDPOINTING_MS=700

# Edge TTS voice (custom pipeline only)
EDGE_TTS_VOICE=en-US-JennyNeural

# Vapi — https://dashboard.vapi.ai
VAPI_API_KEY=your_vapi_private_key
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id
# Optional: reuse a saved dashboard assistant (else transient assistant per call)
VAPI_ASSISTANT_ID=
# Webhook (defaults to PUBLIC_BASE_URL/webhooks/vapi)
VAPI_SERVER_URL=
VAPI_VOICE_PROVIDER=openai
VAPI_VOICE_ID=alloy

# Local dev
FASTAPI_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000
