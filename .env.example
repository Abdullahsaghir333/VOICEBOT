# Copy to .env and fill in your values. Never commit .env.

# Public HTTPS URL — Twilio webhooks + WebSocket (ngrok locally, real domain in production)
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=voicebot

# Twilio (outbound calls + Media Streams)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15551234567
# How long the phone rings before no-answer (minimum 60, max 600 seconds)
TWILIO_CALL_TIMEOUT=60

# Deepgram (speech-to-text) — DEEPGRAM_API_KEY or legacy alias STT=
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_MODEL=nova-2-phonecall
STT_TURN_DEBOUNCE_MS=1100
STT_ENDPOINTING_MS=700

# Groq (LLM)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Edge TTS (text-to-speech)
EDGE_TTS_VOICE=en-US-JennyNeural
EDGE_TTS_VOICE_URDU=ur-PK-UzmaNeural

# Local dev (match run_api.bat port)
API_HOST=0.0.0.0
API_PORT=8001
FASTAPI_URL=http://127.0.0.1:8001
