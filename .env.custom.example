# Custom pipeline only (no Vapi) — copy to .env

PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app

# Reuse your other app's Atlas URI here — same cluster is fine
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0
# alias also works: MONGO_URI=...
# Use a different DB name so collections don't mix with your other app
MONGODB_DB_NAME=voicebot

TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

DEEPGRAM_API_KEY=your_deepgram_key
# or: STT=your_deepgram_key

GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
EDGE_TTS_VOICE=en-US-JennyNeural

API_PORT=8001
FASTAPI_URL=http://127.0.0.1:8001
